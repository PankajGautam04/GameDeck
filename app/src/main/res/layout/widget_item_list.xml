<?xml version="1.0" encoding="utf-8"?>
<!-- List row: rounded cover + title + chevron -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_item_bg"
    android:paddingStart="10dp"
    android:paddingEnd="14dp">

    <!-- Cover image — rounded via bitmap processing -->
    <ImageView
        android:id="@+id/widget_game_cover"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:contentDescription="@string/game_cover"
        android:scaleType="fitCenter"
        android:background="@android:color/transparent" />

    <TextView
        android:id="@+id/widget_game_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:shadowColor="#80000000"
        android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3"
        android:letterSpacing="0.01" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />
</LinearLayout>

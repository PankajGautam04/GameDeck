<?xml version="1.0" encoding="utf-8"?>
<!-- Stack card: fills 100% of StackView. All bitmaps are pre-cropped to same shape. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <!-- Cover image: fitXY because bitmap is already center-cropped to widget aspect ratio -->
    <ImageView
        android:id="@+id/widget_game_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/game_cover"
        android:scaleType="fitXY" />

    <!-- Game title: pill badge, bottom-center, over the baked gradient -->
    <TextView
        android:id="@+id/widget_game_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:background="@drawable/title_pill_bg"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        android:visibility="gone" />
</FrameLayout>

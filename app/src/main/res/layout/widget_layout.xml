<?xml version="1.0" encoding="utf-8"?>
<!-- Manual Cycle Mode: Blur bg + glass container + single image + play button + dots -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Blurred wallpaper background -->
    <ImageView
        android:id="@+id/widget_blur_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Glass container -->
    <FrameLayout
        android:id="@+id/widget_glass_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_background"
        android:padding="4dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Main Game Cover -->
            <ImageView
                android:id="@+id/widget_game_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:contentDescription="@string/game_cover" />

            <!-- GIF Overlay -->
            <ImageView
                android:id="@+id/widget_gif_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:visibility="gone"
                android:contentDescription="@null" />

            <!-- Pagination Dots Container (Middle Right) -->
            <LinearLayout
                android:id="@+id/widget_dots_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="4dp" />

            <!-- Invisible Click Targets -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <FrameLayout
                    android:id="@+id/widget_click_target"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="3" />
                <FrameLayout
                    android:id="@+id/widget_btn_play"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
            <TextView
                android:id="@+id/widget_empty_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/widget_empty_message"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:visibility="gone" />

        </FrameLayout>

    </FrameLayout>
</FrameLayout>
